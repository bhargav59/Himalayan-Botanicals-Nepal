generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String   @default("")
  company   String   @default("")
  country   String   @default("")
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteRequest {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String   @default("")
  company      String   @default("")
  country      String   @default("")
  product      String
  quantity     String
  packaging    String   @default("")
  requirements String   @default("")
  status       QuoteStatus @default(PENDING)
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum QuoteStatus {
  PENDING
  QUOTED
  ACCEPTED
  REJECTED
  CLOSED
}

model AdminUser {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          AdminRole @default(EDITOR)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum AdminRole {
  ADMIN
  EDITOR
  VIEWER
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
}
